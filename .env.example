# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/accounting

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Service URLs
AUTH_SERVICE_URL=http://localhost:8001
TENANT_SERVICE_URL=http://localhost:8002

# Same value on tenant-service and coa-service for delegated RBAC (US-3).
TENANT_INTERNAL_API_TOKEN=

# Optional; not used for code-based email verification.
AUTH_SERVICE_PUBLIC_URL=http://localhost:8001

# Auth service — email verification (SMTP via fastapi-mail; numeric code in email, no links)
# QQ Mail: use port 465 (SMTPS, implicit SSL). SMTP_PASSWORD = mail authorization code.
# For STARTTLS (e.g. port 587), set SMTP_PORT=587 and SMTP_USE_TLS=true.
FRONTEND_URL=http://localhost:3000
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your-address@qq.com
SMTP_PASSWORD=your-qq-mail-authorization-code
SMTP_FROM_EMAIL=your-address@qq.com
SMTP_FROM_NAME=Accounting Platform
SMTP_USE_TLS=true
EMAIL_VERIFICATION_REQUIRED=true
AUTH_EMAIL_VERIFY_CODE_LENGTH=6
AUTH_EMAIL_VERIFY_CODE_EXPIRE_MINUTES=10
AUTH_EMAIL_VERIFY_CODE_MAX_ATTEMPTS=5
AUTH_EMAIL_VERIFY_CODE_RESEND_COOLDOWN_SECONDS=60
# Legacy; unused for code flow (kept for backward-compatible .env)
AUTH_EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=24
